# ── Скопируй в .env и заполни своими данными ──

# Порт, на котором работает API
PORT=3001

# Откуда разрешены запросы (домен сайта). Через запятую можно несколько.
ALLOWED_ORIGINS=http://localhost:5173,https://твой-домен.ru

# ── SMTP сервера (почта, с которой ОТПРАВЛЯЮТСЯ письма) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@твой-домен.ru
SMTP_PASS=пароль_от_почты

# От кого приходит письмо (обычно тот же SMTP_USER)
MAIL_FROM="Сайт Надежды <noreply@твой-домен.ru>"

# ── Куда ПРИХОДЯТ заявки (можно указать позже) ──
MAIL_TO=куда-слать-заявки@example.com
